// QuoteFlow — Standard Package database schema.
//
// This file is a direct, faithful translation of
// docs/QuoteFlow_Standard_Package_Database_Architecture.md (the single source
// of truth). 16 entities, row-level multi-tenancy via `organizationId` on every
// tenant-owned table. Money is always Prisma `Decimal`, never Float. No soft
// deletes and no AuditLog at this tier — both deliberately excluded.
//
// Phase 2.1 hardening (applied while the DB was empty, no architecture change):
//   - Native `@db.Uuid` for every id / foreign key / polymorphic entityId.
//   - `organizationId` indexed on QuoteItem and Payment (completes the tenancy
//     design — those columns exist for indexed single-WHERE scoping).
//   - Foreign-key indexes added only where they back common queries/joins.
//   - Quote → QuoteItem set to onDelete: Cascade (owned children).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  STAFF
  FIELD
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum ServiceUnitType {
  HOUR
  FLAT
  UNIT
  CUSTOM
}

enum DiscountType {
  PERCENT
  FIXED
}

enum PaymentMethod {
  CASH
  CARD
  BANK
  OTHER
}

enum TaskStatus {
  OPEN
  DONE
}

// Polymorphic target type for Activity / Note / Task. `entityId` is NOT a
// DB-enforced foreign key — referential integrity here is the application
// layer's responsibility (documented trade-off, Section 8).
//
// Phase 4 (Step 2): the Activity table is already polymorphic per this enum, so
// no leadId→entityType/entityId migration is required (the frozen Phase 2 shape
// already satisfies it). ORGANIZATION is added additively so org-level events
// (e.g. `settings_updated`, emitted by the Configuration Service) can be logged
// against the polymorphic timeline.
enum EntityType {
  LEAD
  QUOTE
  JOB
  CUSTOMER
  INVOICE
  ORGANIZATION
}

// ---------------------------------------------------------------------------
// Core tenancy & auth
// ---------------------------------------------------------------------------

model Organization {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  slug              String   @unique
  logoUrl           String?
  timezone          String
  currency          String // ISO 4217
  settings          Json // terminology/branding overrides
  // Phase 4 (§29): atomic sequence counters for human-facing quote/invoice
  // numbers. Dedicated Int columns — never JSON — so a single
  // `UPDATE ... SET x = x + 1 RETURNING x` increments them with the database's
  // own row-level locking serializing concurrent callers (lib/numbering).
  nextQuoteNumber   Int      @default(1)
  nextInvoiceNumber Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  customers         Customer[]
  serviceCategories ServiceCategory[]
  services          Service[]
  taxRates          TaxRate[]
  leadSources       LeadSource[]
  leads             Lead[]
  quotes            Quote[]
  quoteItems        QuoteItem[]
  jobs              Job[]
  invoices          Invoice[]
  payments          Payment[]
  activities        Activity[]
  notes             Note[]
  tasks             Task[]
  notifications     Notification[]

  // Phase 6 (§7.2) — back-relations for the new infrastructure tables. These are
  // relation fields only (no new column on Organization); each child carries the
  // `organizationId` FK that enforces tenancy, exactly as every Phase 2–5 table does.
  emailLogs          EmailLog[]
  fileAttachments    FileAttachment[]
  apiKeys            ApiKey[]
  webhooks           Webhook[]
  automationRules    AutomationRule[]
  integrations       Integration[]
  portalAccessTokens PortalAccessToken[]
  aiUsageLogs        AiUsageLog[]
}

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  organizationId          String    @db.Uuid
  name                    String
  email                   String
  passwordHash            String?
  role                    Role
  isActive                Boolean   @default(true)
  lastLoginAt             DateTime?
  // Phase 6 (§7.2) — additive, nullable. `null` means "all channels enabled," so
  // no backfill is required for existing rows. Shape:
  // { inApp: boolean, email: boolean, mutedTypes: string[] }. A real column (not
  // JSON-on-Organization) because it is per-user state, not per-tenant config.
  notificationPreferences Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  // Back-relations for the many FKs that point at User.
  assignedLeads  Lead[]
  createdQuotes  Quote[]        @relation("QuoteCreatedBy")
  assignedQuotes Quote[]        @relation("QuoteAssignedTo")
  assignedJobs   Job[]
  activities     Activity[]
  authoredNotes  Note[]
  assignedTasks  Task[]         @relation("TaskAssignedTo")
  createdTasks   Task[]         @relation("TaskCreatedBy")
  notifications  Notification[]

  // Phase 6 (§7.2) — only the two new tables that carry an actual `@relation` to
  // User (FileAttachment.uploadedBy, ApiKey.createdBy) get a back-relation here.
  // The other new tables store `createdById` as a plain Uuid (no relation field),
  // matching the doc's own model definitions.
  fileAttachments FileAttachment[]
  apiKeys         ApiKey[]

  // Scoped, not global: two orgs can each onboard the same email independently.
  @@unique([organizationId, email])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Customer module
// ---------------------------------------------------------------------------

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  type           CustomerType
  email          String?
  phone          String?
  address        Json? // single field; Standard tier has no billing/shipping split
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  leads    Lead[]
  quotes   Quote[]
  jobs     Job[]
  invoices Invoice[]

  // Phase 6 (§7.2.7) — the Customer Portal's stored, revocable access tokens.
  portalAccessTokens PortalAccessToken[]

  @@index([organizationId])
  @@index([organizationId, email])
}

// ---------------------------------------------------------------------------
// Services / catalog module
// ---------------------------------------------------------------------------

model ServiceCategory {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  sortOrder      Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  services     Service[]

  @@index([organizationId])
}

model Service {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  categoryId     String?         @db.Uuid
  name           String
  description    String?
  sku            String?
  unitType       ServiceUnitType
  price          Decimal         @db.Decimal(10, 2)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
  quoteItems   QuoteItem[]

  @@unique([organizationId, sku])
  @@index([organizationId, isActive])
  @@index([categoryId])
}

model TaxRate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  rate           Decimal  @db.Decimal(5, 2)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  quoteItems   QuoteItem[]

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Leads & pipeline module
// ---------------------------------------------------------------------------

model LeadSource {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  costPerLead    Decimal? @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  leads        Lead[]

  @@index([organizationId])
}

model Lead {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @db.Uuid
  name           String
  email          String?
  phone          String
  sourceId       String?    @db.Uuid
  status         LeadStatus @default(NEW)
  lostReason     String? // drives loss-pattern reporting
  assignedToId   String?    @db.Uuid
  customerId     String?    @db.Uuid
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  source       LeadSource?  @relation(fields: [sourceId], references: [id])
  assignedTo   User?        @relation(fields: [assignedToId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  quotes       Quote[]

  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([sourceId])
  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Quotes module
// ---------------------------------------------------------------------------

model Quote {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  quoteNumber    String // sequential, human-facing
  leadId         String?       @db.Uuid
  customerId     String        @db.Uuid // required
  status         QuoteStatus   @default(DRAFT)
  version        Int           @default(1)
  parentQuoteId  String?       @db.Uuid // revision chain — self relation
  discountType   DiscountType?
  discountValue  Decimal?      @db.Decimal(10, 2)
  subtotal       Decimal       @db.Decimal(10, 2)
  taxAmount      Decimal       @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  currency       String
  issueDate      DateTime?
  expiryDate     DateTime?
  sentAt         DateTime?
  viewedAt       DateTime?
  acceptedAt     DateTime?
  declinedAt     DateTime?
  createdById    String        @db.Uuid
  assignedToId   String        @db.Uuid
  notes          String?       @db.Text
  terms          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  lead         Lead?        @relation(fields: [leadId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  parent       Quote?       @relation("QuoteRevisions", fields: [parentQuoteId], references: [id])
  revisions    Quote[]      @relation("QuoteRevisions")
  createdBy    User         @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  assignedTo   User         @relation("QuoteAssignedTo", fields: [assignedToId], references: [id])
  items        QuoteItem[]
  job          Job?

  @@unique([organizationId, quoteNumber])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([leadId])
  @@index([parentQuoteId])
  @@index([assignedToId])
}

model QuoteItem {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  quoteId        String  @db.Uuid
  serviceId      String? @db.Uuid // null = ad-hoc custom line
  description    String
  quantity       Decimal @db.Decimal(10, 2)
  unitPrice      Decimal @db.Decimal(10, 2)
  lineTotal      Decimal @db.Decimal(10, 2)
  taxRateId      String? @db.Uuid
  sortOrder      Int

  organization Organization @relation(fields: [organizationId], references: [id])
  quote        Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  service      Service?     @relation(fields: [serviceId], references: [id])
  taxRate      TaxRate?     @relation(fields: [taxRateId], references: [id])

  @@index([organizationId])
  @@index([quoteId])
}

// ---------------------------------------------------------------------------
// Jobs & billing module
// ---------------------------------------------------------------------------

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  quoteId        String    @unique @db.Uuid // one job per accepted quote
  customerId     String    @db.Uuid
  assignedToId   String?   @db.Uuid
  status         JobStatus @default(SCHEDULED)
  scheduledDate  DateTime?
  // Phase 6 (§7.2) — additive, nullable. `scheduledDate` (frozen) remains the
  // event start; `scheduledEndAt` is the optional end, enabling real calendar
  // event blocks and conflict detection (§13). A Job without it renders as a
  // point-in-time marker — unchanged behavior for every pre-existing row.
  scheduledEndAt DateTime?
  completedAt    DateTime?
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  quote        Quote        @relation(fields: [quoteId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  assignedTo   User?        @relation(fields: [assignedToId], references: [id])
  invoices     Invoice[]

  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([customerId])
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  jobId          String        @db.Uuid // intentionally NOT unique — deposit/progress/final
  customerId     String        @db.Uuid
  invoiceNumber  String
  amount         Decimal       @db.Decimal(10, 2)
  paidAmount     Decimal       @db.Decimal(10, 2)
  status         InvoiceStatus @default(UNPAID)
  dueDate        DateTime?
  issuedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  job          Job          @relation(fields: [jobId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  payments     Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@index([jobId])
  @@index([customerId])
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @db.Uuid
  invoiceId      String        @db.Uuid
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  reference      String?
  paidAt         DateTime
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])

  @@index([organizationId])
  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// Cross-cutting (polymorphic — entityId is not a DB-enforced FK)
// ---------------------------------------------------------------------------

model Activity {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @db.Uuid
  entityType     EntityType
  entityId       String     @db.Uuid
  type           String
  message        String?
  createdById    String     @db.Uuid
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId, entityType, entityId])
}

// Phase 4 (§30): in-app notification persistence. Extended beyond a bare
// announcement with priority, a clickable action target, and structured
// metadata. `priority` is a string in V1 ("LOW" | "NORMAL" | "HIGH"), promoted
// to an enum once the set is proven stable. `metadata` is app-internal data
// only — never rendered as trusted markup (§22 Security Review).
model Notification {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  userId         String      @db.Uuid
  type           String
  title          String
  body           String?
  priority       String      @default("NORMAL")
  entityType     EntityType?
  entityId       String?     @db.Uuid
  actionUrl      String?
  actionLabel    String?
  metadata       Json?
  isRead         Boolean     @default(false)
  readAt         DateTime?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, userId, isRead, createdAt])
}

model Note {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @db.Uuid
  entityType     EntityType
  entityId       String     @db.Uuid
  content        String     @db.Text
  createdById    String     @db.Uuid
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId, entityType, entityId])
}

model Task {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  entityType     EntityType? // nullable — general tasks allowed
  entityId       String?     @db.Uuid
  title          String
  dueDate        DateTime?
  status         TaskStatus  @default(OPEN)
  assignedToId   String      @db.Uuid
  createdById    String      @db.Uuid
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  assignedTo   User         @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdBy    User         @relation("TaskCreatedBy", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([assignedToId])
}

// ===========================================================================
// Phase 6 — Advanced Platform infrastructure persistence (§7.2)
//
// Faithful translation of QuoteFlow_Phase6_Advanced_Platform_Architecture.md
// §7.2.1–7.2.8 — the document's complete and exhaustive list of new persistence.
// Every table is additive; nothing frozen is renamed, retyped, or removed. Each
// table carries `organizationId` for row-level tenancy, exactly as every Phase
// 2–5 tenant-owned table does, except WebhookDelivery / AutomationLog which are
// children of an already-scoped parent (Webhook / AutomationRule). Free-text
// `status`/`type` strings follow the frozen Activity.type / Notification.type
// precedent for open-ended, additive taxonomies. Polymorphic `entityType`/
// `entityId` reuses the existing EntityType enum and the already-accepted
// "entityId is not a DB-enforced FK" trade-off (frozen DB doc §8).
// ===========================================================================

// §7.2.1 — single source of truth for "was this email attempted, and what happened."
model EmailLog {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id])
  toEmail           String
  fromEmail         String
  subject           String
  templateType      String // "quote_sent" | "invoice_sent" | "payment_confirmation" | ...
  relatedEntityType EntityType?
  relatedEntityId   String?      @db.Uuid
  status            String       @default("QUEUED") // QUEUED | SIMULATED | SENT | DELIVERED | BOUNCED | FAILED
  providerMessageId String? // null under ConsoleEmailProvider
  attempts          Int          @default(0)
  lastError         String?
  sentAt            DateTime?
  createdAt         DateTime     @default(now())

  @@index([organizationId, status, createdAt])
  @@index([organizationId, relatedEntityType, relatedEntityId])
}

// §7.2.2 — polymorphic attachment. `url` is a pasted URL today, a Vercel Blob URL
// tomorrow — identical column, zero migration. `entityType` null = org-level file.
model FileAttachment {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  entityType     EntityType?
  entityId       String?      @db.Uuid
  url            String
  fileName       String
  mimeType       String?
  sizeBytes      Int? // nullable — URL-paste mode often can't know this
  category       String // PHOTO | BEFORE | AFTER | DOCUMENT | ATTACHMENT
  uploadedById   String       @db.Uuid
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId, entityType, entityId])
}

// §7.2.3 — Public API key. Only the bcrypt `hashedKey` is stored; the full key is
// shown once at creation and never persisted. `keyPrefix` enables an indexed
// narrowing step before the bcrypt-compare loop (§21.6, §21.9).
model ApiKey {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String // owner-given label, e.g. "Zapier integration"
  keyPrefix      String // first chars shown in UI / used to narrow the bcrypt set
  hashedKey      String // bcrypt hash of the full key — never store plaintext
  scopes         String[] // e.g. ["leads:read", "quotes:write"] — §21.8 fixed list
  lastUsedAt     DateTime?
  isActive       Boolean      @default(true)
  createdById    String       @db.Uuid
  createdBy      User         @relation(fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  revokedAt      DateTime?

  @@index([organizationId, isActive])
}

// §7.2.4 — outbound webhook subscription. `secret` is an HMAC *signing* secret the
// server needs back to sign each delivery (distinct from the auth tokens above,
// which are one-way hashed); it is generated server-side and shown once.
model Webhook {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @db.Uuid
  organization     Organization      @relation(fields: [organizationId], references: [id])
  url              String
  secret           String // HMAC signing secret, shown once at creation
  subscribedEvents String[] // e.g. ["quote.accepted", "invoice.paid"]
  isActive         Boolean           @default(true)
  createdById      String            @db.Uuid
  createdAt        DateTime          @default(now())
  deliveries       WebhookDelivery[]

  @@index([organizationId, isActive])
}

// §7.2.4 — per-attempt delivery record backing the retry policy.
model WebhookDelivery {
  id                 String    @id @default(uuid()) @db.Uuid
  webhookId          String    @db.Uuid
  webhook            Webhook   @relation(fields: [webhookId], references: [id])
  eventType          String
  payload            Json
  status             String    @default("PENDING") // PENDING | SUCCESS | FAILED
  responseStatusCode Int?
  attempts           Int       @default(0)
  lastAttemptAt      DateTime?
  nextRetryAt        DateTime?
  createdAt          DateTime  @default(now())

  @@index([webhookId, status, nextRetryAt])
}

// §7.2.5 — automation rule. `conditions`/`actions` are JSON (open-ended, evaluated
// by the engine in a later step). The (organizationId, triggerType, isActive)
// index backs the hot trigger-lookup path (§15).
model AutomationRule {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  organization   Organization    @relation(fields: [organizationId], references: [id])
  name           String
  triggerType    String // e.g. "quote.accepted", "invoice.overdue"
  triggerEntity  EntityType?
  conditions     Json // e.g. { field: "total", op: "gte", value: 5000 }
  actions        Json // ordered array: [{ type: "send_notification", params: {...} }, ...]
  isActive       Boolean         @default(true)
  createdById    String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  logs           AutomationLog[]

  @@index([organizationId, triggerType, isActive])
}

// §7.2.5 — per-execution audit row for an automation rule.
model AutomationLog {
  id            String         @id @default(uuid()) @db.Uuid
  ruleId        String         @db.Uuid
  rule          AutomationRule @relation(fields: [ruleId], references: [id])
  entityType    EntityType?
  entityId      String?        @db.Uuid
  status        String // SUCCESS | FAILED | SKIPPED
  resultMessage String?
  executedAt    DateTime       @default(now())

  @@index([ruleId, executedAt])
}

// §7.2.6 — third-party integration connection record. `config` holds NON-SECRET
// metadata only; real credentials never live here (§20.9 credential rule). One
// connection per (organization, provider).
model Integration {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  provider       String // "quickbooks" | "google_calendar" | "stripe" | ...
  status         String       @default("NOT_CONNECTED") // NOT_CONNECTED | CONNECTED | ERROR
  config         Json? // non-secret config only — see §20.9
  connectedAt    DateTime?
  lastSyncAt     DateTime?
  createdById    String       @db.Uuid
  createdAt      DateTime     @default(now())

  @@unique([organizationId, provider])
}

// §7.2.7 — the Customer Portal's stored, revocable access token. Only the bcrypt
// `tokenHash` is stored. Distinct from and coexisting with the frozen Phase 5
// per-Quote HMAC share link (lib/tokens.ts), which is unchanged (§12.10).
model PortalAccessToken {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  customerId     String       @db.Uuid
  customer       Customer     @relation(fields: [customerId], references: [id])
  tokenHash      String // bcrypt hash of the issued token — never store plaintext
  label          String? // e.g. "Sent via text 6/28"
  expiresAt      DateTime?
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdById    String       @db.Uuid
  createdAt      DateTime     @default(now())

  @@index([organizationId, customerId])
}

// §7.2.8 — AI cost/usage ledger. Written by NullAIProvider too (tokensUsed=0,
// costEstimate=0) so cost reporting is correct from day one. `costEstimate` is a
// Decimal (never Float), consistent with the frozen money discipline (§5).
model AiUsageLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  feature        String // "quote_draft" | "email_draft" | "lead_priority" | ...
  provider       String // "null" | "anthropic" | "openai"
  tokensUsed     Int?
  costEstimate   Decimal?     @db.Decimal(10, 4)
  createdById    String       @db.Uuid
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}
