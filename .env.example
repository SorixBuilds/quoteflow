# QuoteFlow environment variables
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Phase 1 (framework) ---
# Public base URL of the app.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Phase 2 (database) ---
# Postgres connection string (Neon). Use the direct/unpooled endpoint so Prisma
# Migrate can run against it. Copy your own value into `.env` (git-ignored).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Phase 3 (authentication) ---
# Auth.js session secret — signs/encrypts the JWT session cookie. REQUIRED.
# Generate a unique value per environment, e.g. `npx auth secret` or
# `openssl rand -base64 32`. Never commit a real value; never reuse across envs.
AUTH_SECRET=

# Enables the public self-registration route (/register). Defaults to "false".
# Set to "true" ONLY on the public portfolio/demo deployment. Every real client
# deployment ships with this false (or unset).
ALLOW_PUBLIC_REGISTRATION="false"

# bcrypt work factor for password hashing. Optional — defaults to 12 if unset.
# BCRYPT_COST_FACTOR="12"
