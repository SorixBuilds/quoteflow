# QuoteFlow environment variables
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# --- Phase 1 (framework) ---
# Public base URL of the app.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Phase 2 (database) ---
# Postgres connection string (Neon). Use the direct/unpooled endpoint so Prisma
# Migrate can run against it. Copy your own value into `.env` (git-ignored).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Added in later phases (kept here as a forward reference) ---
# Auth.js session secret — added with the authentication phase.
# AUTH_SECRET=
